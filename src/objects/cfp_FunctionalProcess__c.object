    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>cfp_Early_And_Rapid_Estimation_Size__c</fullName>
        <inlineHelpText>Small:5,
Medium:8,
Large:14,
Very Large:30+</inlineHelpText>
        <label>Early And Rapid Estimation Size</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Small</fullName>
                    <default>false</default>
                    <label>Small</label>
                </value>
                <value>
                    <fullName>Medium</fullName>
                    <default>false</default>
                    <label>Medium</label>
                </value>
                <value>
                    <fullName>Large</fullName>
                    <default>false</default>
                    <label>Large</label>
                </value>
                <value>
                    <fullName>Very Large</fullName>
                    <default>false</default>
                    <label>Very Large</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>cfp_Estimated_Size__c</fullName>
        <externalId>false</externalId>
        <formula>CASE(
  cfp_Early_And_Rapid_Estimation_Size__c,
  &quot;Small&quot;,  5,
  &quot;Medium&quot;,  8,
  &quot;Large&quot;, 14,
		&quot;Very Large&quot;, 30,
  0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Estimated Size</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_Name_Ordered__c</fullName>
        <externalId>false</externalId>
        <formula>cfp_Sub_System__c &amp; &apos;-&apos; &amp; TEXT(cfp_Order__c) &amp; &apos;-&apos; &amp; Name &amp; &apos;-&apos; &amp; TEXT(cfp_Total_Function_Points__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Name Ordered</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_Order__c</fullName>
        <externalId>false</externalId>
        <label>Order</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_Realised_Range__c</fullName>
        <externalId>false</externalId>
        <formula>IF(cfp_Total_Function_Points__c &lt;= 5, &quot;small&quot;,
IF(cfp_Total_Function_Points__c &lt;= 8, &quot;medium&quot;,
IF(cfp_Total_Function_Points__c &lt;= 14,&quot;large&quot;,
&quot;very large&quot;)))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Realised Range</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_Sub_System__c</fullName>
        <externalId>false</externalId>
        <label>Sub System</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_Sum_Of_ootb__c</fullName>
        <label>Sum of OOTB</label>
        <summarizedField>cfp_Data_Movements__c.cfp_isOOTB__c</summarizedField>
        <summaryForeignKey>cfp_Data_Movements__c.cfp_FunctionalProcess__c</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>cfp_Sum_of_Config__c</fullName>
        <label>Sum of Config</label>
        <summarizedField>cfp_Data_Movements__c.cfp_isConfig__c</summarizedField>
        <summaryForeignKey>cfp_Data_Movements__c.cfp_FunctionalProcess__c</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>cfp_Sum_of_LowCode__c</fullName>
        <label>Sum of LowCode</label>
        <summarizedField>cfp_Data_Movements__c.cfp_isLowCode__c</summarizedField>
        <summaryForeignKey>cfp_Data_Movements__c.cfp_FunctionalProcess__c</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>cfp_Sum_of_ProCode__c</fullName>
        <label>Sum of ProCode</label>
        <summarizedField>cfp_Data_Movements__c.cfp_isProCode__c</summarizedField>
        <summaryForeignKey>cfp_Data_Movements__c.cfp_FunctionalProcess__c</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>cfp_System_Context__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>System Context</label>
        <referenceTo>cfp_System_Context__c</referenceTo>
        <relationshipName>dk_FunctionalProcesses</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>cfp_Texttual_Overview__c</fullName>
        <label>Texttual Overview</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Html</type>
        <visibleLines>25</visibleLines>
    </fields>
    <fields>
        <fullName>cfp_Total_Function_Points__c</fullName>
        <externalId>false</externalId>
        <formula>cfp_Sum_of_Config__c +  cfp_Sum_Of_ootb__c  +  cfp_Sum_of_LowCode__c +  cfp_Sum_of_ProCode__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Total Function Points</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_inComplete__c</fullName>
        <externalId>false</externalId>
        <formula>if( cfp_incompleteSteps__c &gt; 0, IMAGE(&quot;/img/samples/color_red.gif&quot;, &quot;Red&quot;, 16, 16), IMAGE(&quot;/img/samples/color_green.gif&quot;, &quot;Green&quot;, 16, 16))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Complete Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_incompleteSteps__c</fullName>
        <label>inComplete Steps</label>
        <summaryFilterItems>
            <field>cfp_Data_Movements__c.cfp_isComplete__c</field>
            <operation>equals</operation>
            <value>False</value>
        </summaryFilterItems>
        <summaryForeignKey>cfp_Data_Movements__c.cfp_FunctionalProcess__c</summaryForeignKey>
        <summaryOperation>count</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>cfp_is_reUsed__c</fullName>
        <defaultValue>false</defaultValue>
        <label>is reUsed</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>cfp_triggeringevent__c</fullName>
        <externalId>false</externalId>
        <label>Triggering Event</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Functional Process</label>

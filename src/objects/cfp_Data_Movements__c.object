    <fields>
        <fullName>cfp_isComplete__c</fullName>
        <formula>if ( cfp_isOOTB__c  + cfp_isConfig__c +	 cfp_isLowCode__c  + cfp_isProCode__c  &gt; 0, true, false)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>isComplete</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>cfp_isConfig__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
  ISPICKVAL(cfp_implementationtype__c, &apos;listview&apos;), 
  cfp_Number_of_ListViews__c, 
  IF(
    ISPICKVAL(cfp_implementationtype__c, &apos;report&apos;), 
    2 * cfp_Number_of_Reports__c,
    IF(
      ISPICKVAL(cfp_implementationtype__c, &apos;automation rule&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;Compact Layout&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;config&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;Flexipage&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;Page Layout&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;Email Template&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;Action Button&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;Criteria Search and Filter&apos;) ||
      ISPICKVAL(cfp_implementationtype__c, &apos;workflow&apos;),
      IF(cfp_is_API_Call__c, 2, 1),
      0
    )
  )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>isConfig</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_isLowCode__c</fullName>
        <externalId>false</externalId>
        <formula>IF(ispickval(cfp_implementationtype__c,&apos;bre&apos;) || 
			ispickval(cfp_implementationtype__c, &apos;flexcard&apos;) || 
			ispickval(cfp_implementationtype__c, &apos;flow&apos;) ||
			ispickval(cfp_implementationtype__c, &apos;omniscript&apos;) || 
			ispickval(cfp_implementationtype__c, &apos;Data Raptor&apos;) || 
			ispickval(cfp_implementationtype__c, &apos;Document Template&apos;) || 
			ispickval(cfp_implementationtype__c, &apos;Exp Builder&apos;) || 		
			ispickval(cfp_implementationtype__c, &apos;Data Processing Engine&apos;) || 		
			ispickval(cfp_implementationtype__c, &apos;Screen Flow&apos;), 
			IF(cfp_is_API_Call__c, 2, 1),
			0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>isLowCode</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_isOOTB__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
    AND(ISPICKVAL(cfp_implementationtype__c, &apos;ootb&apos;), NOT(ISBLANK(cfp_Number_of_ListViews__c))),  
    cfp_Number_of_ListViews__c, 
    IF(
        ISPICKVAL(cfp_implementationtype__c, &apos;ootb&apos;), 
        1, 
        0
    )
)</formula>
        <label>isOOTB</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>cfp_isProCode__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
  (ISPICKVAL(cfp_implementationtype__c, &apos;Apex&apos;) ||
   ISPICKVAL(cfp_implementationtype__c, &apos;aura&apos;) ||
   ISPICKVAL(cfp_implementationtype__c, &apos;lwc&apos;) ||
   ISPICKVAL(cfp_implementationtype__c, &apos;VisualForce&apos;) ||
   ISPICKVAL(cfp_implementationtype__c, &apos;dataweave&apos;)),
  IF(cfp_is_API_Call__c, 2, 1),
  0
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>isProCode</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
